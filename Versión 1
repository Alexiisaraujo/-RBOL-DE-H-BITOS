<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌱 Árbol de Hábitos</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  :root {
    --bg: #0a0a1a;
    --bg2: #111128;
    --panel: #1a1a3a;
    --border: #3a3a6a;
    --green: #00ff88;
    --green2: #00cc66;
    --yellow: #ffdd00;
    --orange: #ff8800;
    --red: #ff3344;
    --blue: #4488ff;
    --purple: #aa44ff;
    --white: #eeeeff;
    --gray: #6666aa;
    --pixel: 4px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; image-rendering: pixelated; }

  body {
    background: var(--bg);
    font-family: 'Press Start 2P', monospace;
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* SCANLINES */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.15) 2px, rgba(0,0,0,0.15) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* STARS BG */
  #stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .star {
    position: absolute;
    width: 2px; height: 2px;
    background: white;
    animation: twinkle 2s infinite;
  }
  @keyframes twinkle {
    0%,100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* LAYOUT */
  #app {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 16px;
  }

  /* HEADER */
  header {
    text-align: center;
    padding: 20px 0 12px;
    border-bottom: 4px solid var(--border);
    margin-bottom: 20px;
  }
  .logo {
    font-size: 18px;
    color: var(--green);
    text-shadow: 0 0 10px var(--green), 2px 2px 0 #003322;
    letter-spacing: 2px;
    animation: glow 2s infinite;
  }
  .subtitle {
    font-size: 7px;
    color: var(--gray);
    margin-top: 8px;
    letter-spacing: 1px;
  }
  @keyframes glow {
    0%,100% { text-shadow: 0 0 8px var(--green), 2px 2px 0 #003322; }
    50% { text-shadow: 0 0 20px var(--green), 0 0 40px var(--green2), 2px 2px 0 #003322; }
  }

  /* DATE BAR */
  .date-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--panel);
    border: 3px solid var(--border);
    padding: 8px 14px;
    margin-bottom: 16px;
    font-size: 7px;
  }
  .date-bar .clock { color: var(--yellow); }
  .date-bar .day-label { color: var(--green); }

  /* MAIN GRID */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 16px;
  }

  /* TREE VIEWPORT */
  .tree-viewport {
    background: var(--panel);
    border: 4px solid var(--border);
    position: relative;
    overflow: hidden;
    min-height: 380px;
  }

  .sky-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #060618 0%, #0d1535 40%, #1a2a1a 70%, #0d1a0d 100%);
  }

  /* GROUND */
  .ground {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 60px;
    background: #1a3a0a;
    border-top: 4px solid #2a5a0f;
  }
  .ground-detail {
    position: absolute;
    top: 4px; left: 0; right: 0;
    height: 4px;
    background: repeating-linear-gradient(90deg, #3a7a1a 0px, #3a7a1a 8px, transparent 8px, transparent 16px);
  }

  /* TREE CANVAS */
  #treeCanvas {
    position: absolute;
    bottom: 56px;
    left: 50%;
    transform: translateX(-50%);
    image-rendering: pixelated;
  }

  /* STAGE LABEL */
  .stage-badge {
    position: absolute;
    top: 10px; left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.7);
    border: 2px solid var(--green);
    padding: 4px 10px;
    font-size: 6px;
    color: var(--green);
    white-space: nowrap;
  }

  /* WEATHER */
  .weather-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .raindrop {
    position: absolute;
    width: 2px;
    background: #44aaff88;
    border-radius: 1px;
    animation: rain linear infinite;
  }
  @keyframes rain {
    from { transform: translateY(-20px); }
    to { transform: translateY(420px); }
  }

  /* PIXEL PARTICLES */
  .particle {
    position: absolute;
    width: 4px; height: 4px;
    pointer-events: none;
    animation: floatUp 2s ease-out forwards;
  }
  @keyframes floatUp {
    0% { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-60px) scale(0.5); }
  }

  /* RIGHT PANEL */
  .right-panel {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* STATS BOX */
  .pixel-box {
    background: var(--panel);
    border: 3px solid var(--border);
    padding: 12px;
  }
  .pixel-box h3 {
    font-size: 7px;
    color: var(--yellow);
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--border);
  }

  /* PROGRESS BAR */
  .stat-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .stat-label { font-size: 6px; color: var(--gray); width: 60px; flex-shrink: 0; }
  .bar-track {
    flex: 1;
    height: 10px;
    background: #0a0a1a;
    border: 2px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    transition: width 0.6s steps(10);
    position: relative;
  }
  .bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(90deg, rgba(255,255,255,0.15) 0px, rgba(255,255,255,0.15) 4px, transparent 4px, transparent 8px);
  }
  .bar-val { font-size: 6px; color: var(--white); width: 28px; text-align: right; }

  /* HABITS LIST */
  .habit-item {
    background: #0f0f2a;
    border: 2px solid var(--border);
    padding: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color 0.1s;
    position: relative;
    overflow: hidden;
  }
  .habit-item:hover { border-color: var(--green); }
  .habit-item.done { border-color: var(--green2); background: #0a1a0a; }
  .habit-item.failed { border-color: var(--red); background: #1a0a0a; opacity: 0.7; }

  .habit-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .habit-name { font-size: 6px; color: var(--white); }
  .habit-check {
    width: 16px; height: 16px;
    border: 2px solid var(--border);
    background: #0a0a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .habit-item.done .habit-check {
    background: var(--green2);
    border-color: var(--green);
    color: #fff;
  }
  .habit-streak { font-size: 5px; color: var(--orange); }
  .habit-freq { font-size: 5px; color: var(--gray); }

  /* MINI PROGRESS */
  .habit-mini-bar { margin-top: 4px; }

  /* BUTTONS */
  .pixel-btn {
    background: var(--panel);
    border: 3px solid var(--green);
    color: var(--green);
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    padding: 8px 12px;
    cursor: pointer;
    width: 100%;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.1s;
    position: relative;
  }
  .pixel-btn:hover {
    background: var(--green);
    color: #000;
    box-shadow: 0 0 12px var(--green);
  }
  .pixel-btn:active { transform: scale(0.97); }
  .pixel-btn.danger { border-color: var(--red); color: var(--red); }
  .pixel-btn.danger:hover { background: var(--red); color: #fff; box-shadow: 0 0 12px var(--red); }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,10,0.85);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--bg2);
    border: 4px solid var(--green);
    padding: 24px;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 0 30px var(--green);
    max-height: 90vh;
    overflow-y: auto;
  }
  .modal-box h2 { font-size: 10px; color: var(--green); margin-bottom: 20px; }

  /* FORM ELEMENTS */
  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 6px; color: var(--gray); margin-bottom: 6px; }
  .pixel-input, .pixel-select {
    width: 100%;
    background: #0a0a1a;
    border: 2px solid var(--border);
    color: var(--white);
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    padding: 8px;
    outline: none;
  }
  .pixel-input:focus, .pixel-select:focus { border-color: var(--green); }
  .pixel-select option { background: #0a0a1a; }

  .icon-grid {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .icon-opt {
    width: 36px; height: 36px;
    border: 2px solid var(--border);
    background: #0a0a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    cursor: pointer;
    transition: border-color 0.1s;
  }
  .icon-opt.selected, .icon-opt:hover { border-color: var(--green); background: #001a0a; }

  .btn-row { display: flex; gap: 8px; margin-top: 16px; }
  .btn-row .pixel-btn { flex: 1; }

  /* NOTIFICATION */
  #notif {
    position: fixed;
    top: 20px; right: 20px;
    background: var(--panel);
    border: 3px solid var(--green);
    padding: 12px 16px;
    font-size: 7px;
    color: var(--green);
    z-index: 9998;
    display: none;
    max-width: 260px;
    box-shadow: 0 0 20px var(--green);
    animation: slideIn 0.3s steps(4);
  }
  @keyframes slideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  /* HISTORY DOTS */
  .history-dots {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .dot {
    width: 8px; height: 8px;
    border: 1px solid var(--border);
  }
  .dot.hit { background: var(--green2); }
  .dot.miss { background: var(--red); opacity: 0.5; }
  .dot.future { background: #0a0a1a; }

  /* MESSAGE BOX */
  .msg-box {
    background: #0a0a1a;
    border: 2px solid var(--border);
    padding: 8px;
    font-size: 6px;
    color: var(--green);
    min-height: 32px;
    line-height: 1.8;
    margin-top: 8px;
  }

  /* STAGE ICONS */
  .stage-info {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
    background: #0a0a1a;
    border: 2px solid var(--border);
    margin-top: 6px;
  }
  .stage-icon { font-size: 24px; }
  .stage-text { font-size: 6px; color: var(--gray); line-height: 1.8; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0a0a1a; }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    .main-grid { grid-template-columns: 1fr; }
    .logo { font-size: 12px; }
  }

  /* PULSE ANIMATION FOR TREE */
  @keyframes treePulse {
    0%,100% { filter: drop-shadow(0 0 4px #00ff8866); }
    50% { filter: drop-shadow(0 0 12px #00ff88aa); }
  }
  #treeCanvas { animation: treePulse 3s infinite; }

  /* DEAD TREE FLICKER */
  @keyframes deadFlicker {
    0%,100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  #treeCanvas.dead { animation: deadFlicker 0.5s infinite; filter: drop-shadow(0 0 4px #ff333466); }

  .empty-state {
    text-align: center;
    padding: 20px 10px;
    font-size: 6px;
    color: var(--gray);
    line-height: 2;
  }
</style>
</head>
<body>

<div id="stars"></div>

<div id="app">
  <header>
    <div class="logo">🌱 ÁRBOL DE HÁBITOS</div>
    <div class="subtitle">TUS HÁBITOS ALIMENTAN TU ÁRBOL. TU DISCIPLINA DECIDE SI CRECE... O MUERE.</div>
  </header>

  <div class="date-bar">
    <span class="day-label" id="dayLabel">DÍA 0</span>
    <span class="clock" id="clock">00:00:00</span>
    <span style="font-size:6px;color:var(--gray)" id="dateLabel">--/--/----</span>
  </div>

  <div class="main-grid">
    <!-- TREE VIEWPORT -->
    <div>
      <div class="tree-viewport">
        <div class="sky-gradient"></div>
        <div class="weather-fx" id="weatherFx"></div>
        <div class="stage-badge" id="stageBadge">✨ SEMILLA</div>
        <canvas id="treeCanvas" width="200" height="280"></canvas>
        <div class="ground"><div class="ground-detail"></div></div>
      </div>

      <!-- STAGE INFO -->
      <div class="stage-info" id="stageInfo">
        <span class="stage-icon" id="stageIcon">🌰</span>
        <div class="stage-text" id="stageText">Planta tu primera semilla.<br>Completa hábitos para verla crecer.</div>
      </div>

      <!-- TREE MESSAGE -->
      <div class="msg-box" id="treeMsg">▶ Bienvenido. Agrega tus primeros hábitos y comienza tu viaje.</div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">

      <!-- OVERALL STATS -->
      <div class="pixel-box">
        <h3>📊 ESTADÍSTICAS</h3>
        <div class="stat-row">
          <span class="stat-label">SALUD</span>
          <div class="bar-track"><div class="bar-fill" id="healthBar" style="width:100%;background:var(--green)"></div></div>
          <span class="bar-val" id="healthVal">100%</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">PROGRESO</span>
          <div class="bar-track"><div class="bar-fill" id="progressBar" style="width:0%;background:var(--blue)"></div></div>
          <span class="bar-val" id="progressVal">0%</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">RACHA</span>
          <div class="bar-track"><div class="bar-fill" id="streakBar" style="width:0%;background:var(--orange)"></div></div>
          <span class="bar-val" id="streakVal">0d</span>
        </div>
      </div>

      <!-- HABITS -->
      <div class="pixel-box" style="flex:1">
        <h3>🎯 MIS HÁBITOS HOY</h3>
        <div id="habitsList">
          <div class="empty-state">
            NO HAY HÁBITOS.<br>¡AGREGA UNO PARA<br>COMENZAR!
          </div>
        </div>
        <button class="pixel-btn" onclick="openModal()" style="margin-top:8px">+ NUEVO HÁBITO</button>
      </div>

      <!-- HISTORY -->
      <div class="pixel-box">
        <h3>📅 HISTORIAL (7D)</h3>
        <div id="historyGrid"></div>
      </div>

    </div>
  </div>
</div>

<!-- ADD HABIT MODAL -->
<div class="modal-overlay" id="habitModal">
  <div class="modal-box">
    <h2>🌱 NUEVO HÁBITO</h2>

    <div class="form-group">
      <label>NOMBRE DEL HÁBITO</label>
      <input class="pixel-input" id="habitName" placeholder="Ej: Hacer ejercicio" maxlength="24">
    </div>

    <div class="form-group">
      <label>ICONO</label>
      <div class="icon-grid" id="iconGrid">
        <!-- filled by JS -->
      </div>
    </div>

    <div class="form-group">
      <label>FRECUENCIA</label>
      <select class="pixel-select" id="habitFreq">
        <option value="daily">Todos los días</option>
        <option value="3pw">3 veces por semana</option>
        <option value="4pw">4 veces por semana</option>
        <option value="weekly">1 vez por semana</option>
      </select>
    </div>

    <div class="form-group">
      <label>DURACIÓN TOTAL</label>
      <select class="pixel-select" id="habitDuration">
        <option value="7">1 semana (7 días)</option>
        <option value="30">1 mes (30 días)</option>
        <option value="90">3 meses (90 días)</option>
        <option value="180">6 meses (180 días)</option>
        <option value="365">1 año (365 días)</option>
      </select>
    </div>

    <div class="btn-row">
      <button class="pixel-btn danger" onclick="closeModal()">✕ CANCELAR</button>
      <button class="pixel-btn" onclick="saveHabit()">✓ GUARDAR</button>
    </div>
  </div>
</div>

<!-- NOTIFICATION -->
<div id="notif"></div>

<script>
// ─── DATA ───────────────────────────────────────────────────────────────────

const ICONS = ['💪','🥗','💧','📚','🧘','💰','😴','🏃','🎨','✍️','🎸','🧹','❤️','🧠','🚫'];
let selectedIcon = ICONS[0];

const STAGES = [
  { min: 0,   max: 5,   label: 'SEMILLA',      icon: '🌰', desc: 'Planta tu primera semilla.\nCompleta hábitos para verla crecer.' },
  { min: 6,   max: 15,  label: 'BROTE',         icon: '🌱', desc: 'Los primeros brotes aparecen.\n¡Sigue así, la constancia es clave!' },
  { min: 16,  max: 30,  label: 'PLANTA JOVEN',  icon: '🌿', desc: 'Una rutina estable. Tu planta\ncomienza a tomar forma.' },
  { min: 31,  max: 55,  label: 'PLANTA FUERTE', icon: '🌲', desc: 'Gran disciplina. El árbol crece\ncon fuerza y determinación.' },
  { min: 56,  max: 80,  label: 'ÁRBOL GRANDE',  icon: '🌳', desc: '¡Objetivo casi cumplido!\nEres un ejemplo de constancia.' },
  { min: 81,  max: 100, label: 'ÁRBOL LEGENDARIO', icon: '✨', desc: '¡LEYENDA! Tu árbol es magnífico.\nHas dominado tus hábitos.' },
];

function loadData() {
  return JSON.parse(localStorage.getItem('habitTree') || '{"habits":[],"startDate":null}');
}
function saveData(d) {
  localStorage.setItem('habitTree', JSON.stringify(d));
}

function getTodayStr() {
  const n = new Date();
  return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}-${String(n.getDate()).padStart(2,'0')}`;
}

function getStartDate(data) {
  if (!data.startDate) {
    data.startDate = getTodayStr();
    saveData(data);
  }
  return data.startDate;
}

function daysDiff(a, b) {
  const da = new Date(a), db = new Date(b);
  return Math.floor((db - da) / 86400000);
}

// ─── CLOCK ───────────────────────────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const hh = String(now.getHours()).padStart(2,'0');
  const mm = String(now.getMinutes()).padStart(2,'0');
  const ss = String(now.getSeconds()).padStart(2,'0');
  document.getElementById('clock').textContent = `${hh}:${mm}:${ss}`;
  document.getElementById('dateLabel').textContent =
    `${String(now.getDate()).padStart(2,'0')}/${String(now.getMonth()+1).padStart(2,'0')}/${now.getFullYear()}`;

  const data = loadData();
  const start = getStartDate(data);
  const dayNum = daysDiff(start, getTodayStr()) + 1;
  document.getElementById('dayLabel').textContent = `DÍA ${dayNum}`;
}
setInterval(updateClock, 1000);
updateClock();

// ─── STARS ───────────────────────────────────────────────────────────────────
(function() {
  const c = document.getElementById('stars');
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    s.style.left = Math.random()*100 + '%';
    s.style.top = Math.random()*60 + '%';
    s.style.animationDelay = Math.random()*3 + 's';
    s.style.animationDuration = (1.5 + Math.random()*2) + 's';
    c.appendChild(s);
  }
})();

// ─── ICON GRID ────────────────────────────────────────────────────────────────
function buildIconGrid() {
  const g = document.getElementById('iconGrid');
  g.innerHTML = '';
  ICONS.forEach(ic => {
    const d = document.createElement('div');
    d.className = 'icon-opt' + (ic === selectedIcon ? ' selected' : '');
    d.textContent = ic;
    d.onclick = () => {
      selectedIcon = ic;
      buildIconGrid();
    };
    g.appendChild(d);
  });
}
buildIconGrid();

// ─── MODAL ────────────────────────────────────────────────────────────────────
function openModal() {
  document.getElementById('habitModal').classList.add('open');
  document.getElementById('habitName').value = '';
  selectedIcon = ICONS[0];
  buildIconGrid();
}
function closeModal() {
  document.getElementById('habitModal').classList.remove('open');
}

function saveHabit() {
  const name = document.getElementById('habitName').value.trim();
  if (!name) { showNotif('⚠ Ingresa un nombre para el hábito!', 'red'); return; }
  const data = loadData();
  getStartDate(data);

  data.habits.push({
    id: Date.now(),
    name,
    icon: selectedIcon,
    freq: document.getElementById('habitFreq').value,
    duration: parseInt(document.getElementById('habitDuration').value),
    createdAt: getTodayStr(),
    log: {},   // { "YYYY-MM-DD": true/false }
  });
  saveData(data);
  closeModal();
  showNotif(`✅ "${name}" agregado!`, 'green');
  render();
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
let notifTimeout;
function showNotif(msg, color = 'green') {
  const el = document.getElementById('notif');
  el.textContent = msg;
  el.style.borderColor = color === 'red' ? 'var(--red)' : 'var(--green)';
  el.style.color = color === 'red' ? 'var(--red)' : 'var(--green)';
  el.style.display = 'block';
  clearTimeout(notifTimeout);
  notifTimeout = setTimeout(() => el.style.display = 'none', 2800);
}

// ─── HABITS LIST ─────────────────────────────────────────────────────────────
function shouldDoToday(habit, todayStr) {
  const dow = new Date(todayStr).getDay(); // 0=Sun
  if (habit.freq === 'daily') return true;
  if (habit.freq === '3pw') return [1,3,5].includes(dow);
  if (habit.freq === '4pw') return [1,2,4,6].includes(dow);
  if (habit.freq === 'weekly') return dow === 1;
  return true;
}

function renderHabits(data) {
  const today = getTodayStr();
  const el = document.getElementById('habitsList');
  if (!data.habits.length) {
    el.innerHTML = '<div class="empty-state">NO HAY HÁBITOS.<br>¡AGREGA UNO PARA<br>COMENZAR!</div>';
    return;
  }

  el.innerHTML = '';
  data.habits.forEach(h => {
    const active = shouldDoToday(h, today);
    const done = h.log[today] === true;
    const missed = h.log[today] === false;

    // streak
    let streak = 0;
    let d = new Date(today);
    while (true) {
      const ds = d.toISOString().split('T')[0];
      if (h.log[ds] === true) { streak++; d.setDate(d.getDate()-1); }
      else break;
    }

    // progress
    const totalDays = h.duration;
    const hits = Object.values(h.log).filter(v => v === true).length;
    const pct = Math.min(100, Math.round(hits / totalDays * 100));

    const div = document.createElement('div');
    div.className = 'habit-item' + (done ? ' done' : missed ? ' failed' : '');
    div.innerHTML = `
      <div class="habit-top">
        <span class="habit-name">${h.icon} ${h.name.toUpperCase()}</span>
        <div class="habit-check" onclick="toggleHabit(${h.id})">${done ? '✓' : ''}</div>
      </div>
      <div style="display:flex;justify-content:space-between">
        <span class="habit-streak">${streak > 0 ? '🔥 '+streak+'d racha' : (active ? '▷ Pendiente' : '— No toca hoy')}</span>
        <span class="habit-freq">${pct}% / ${totalDays}d</span>
      </div>
      <div class="habit-mini-bar">
        <div class="bar-track" style="height:6px">
          <div class="bar-fill" style="width:${pct}%;background:${pct>66?'var(--green)':pct>33?'var(--yellow)':'var(--orange)'}"></div>
        </div>
      </div>
    `;
    el.appendChild(div);
  });
}

function toggleHabit(id) {
  const data = loadData();
  const today = getTodayStr();
  const h = data.habits.find(x => x.id === id);
  if (!h) return;

  const was = h.log[today];
  h.log[today] = was ? undefined : true;
  if (h.log[today] === undefined) delete h.log[today];
  saveData(data);
  showNotif(h.log[today] ? `🌱 ¡${h.name} completado!` : `↩ ${h.name} desmarcado`, h.log[today] ? 'green' : 'red');
  spawnParticles();
  render();
}

// ─── HISTORY ─────────────────────────────────────────────────────────────────
function renderHistory(data) {
  const el = document.getElementById('historyGrid');
  el.innerHTML = '';
  if (!data.habits.length) return;

  const today = new Date();
  data.habits.slice(0, 4).forEach(h => {
    const row = document.createElement('div');
    row.style.marginBottom = '8px';
    row.innerHTML = `<div style="font-size:5px;color:var(--gray);margin-bottom:3px">${h.icon} ${h.name.substring(0,14).toUpperCase()}</div>`;

    const dots = document.createElement('div');
    dots.className = 'history-dots';
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const ds = d.toISOString().split('T')[0];
      const dot = document.createElement('div');
      dot.className = 'dot ' + (h.log[ds] === true ? 'hit' : i === 0 && h.log[ds] === undefined ? 'future' : 'miss');
      dots.appendChild(dot);
    }
    row.appendChild(dots);
    el.appendChild(row);
  });
}

// ─── STATS ───────────────────────────────────────────────────────────────────
function computeStats(data) {
  if (!data.habits.length) return { health: 100, progress: 0, streak: 0 };

  const today = getTodayStr();

  // Progress: avg across all habits
  let totalProg = 0;
  data.habits.forEach(h => {
    const hits = Object.values(h.log).filter(v => v === true).length;
    totalProg += Math.min(100, hits / h.duration * 100);
  });
  const progress = Math.round(totalProg / data.habits.length);

  // Streak: consecutive days where at least one habit was done
  let streak = 0;
  let d = new Date(today);
  while (streak < 999) {
    const ds = d.toISOString().split('T')[0];
    const anyDone = data.habits.some(h => h.log[ds] === true);
    if (anyDone) { streak++; d.setDate(d.getDate()-1); }
    else break;
  }

  // Health: drops if habits missed today
  let health = 100;
  const dueToday = data.habits.filter(h => shouldDoToday(h, today));
  if (dueToday.length) {
    const donePct = dueToday.filter(h => h.log[today] === true).length / dueToday.length;
    health = Math.max(0, Math.round(50 + donePct * 50));
    // Also decay if many missed days recently
    let misses = 0;
    for (let i = 1; i <= 3; i++) {
      const dd = new Date(today);
      dd.setDate(dd.getDate()-i);
      const ds = dd.toISOString().split('T')[0];
      data.habits.forEach(h => { if (shouldDoToday(h, ds) && h.log[ds] !== true) misses++; });
    }
    health = Math.max(10, health - misses * 5);
  }

  return { health, progress, streak };
}

function renderStats(data) {
  const { health, progress, streak } = computeStats(data);

  document.getElementById('healthBar').style.width = health + '%';
  document.getElementById('healthBar').style.background = health > 60 ? 'var(--green)' : health > 30 ? 'var(--orange)' : 'var(--red)';
  document.getElementById('healthVal').textContent = health + '%';

  document.getElementById('progressBar').style.width = progress + '%';
  document.getElementById('progressVal').textContent = progress + '%';

  const streakMax = 30;
  document.getElementById('streakBar').style.width = Math.min(100, streak/streakMax*100) + '%';
  document.getElementById('streakVal').textContent = streak + 'd';
}

// ─── STAGE ───────────────────────────────────────────────────────────────────
function getStage(progress) {
  return STAGES.find(s => progress >= s.min && progress <= s.max) || STAGES[0];
}

function renderStage(data) {
  const { progress, health } = computeStats(data);
  const stage = getStage(progress);

  document.getElementById('stageBadge').textContent = `${stage.icon} ${stage.label}`;
  document.getElementById('stageIcon').textContent = stage.icon;
  document.getElementById('stageText').innerHTML = stage.desc.replace('\n','<br>');

  // Tree message
  const msgs = health > 70
    ? ['▶ El árbol florece con tu disciplina.', '▶ ¡Sigue así! Cada día cuenta.', '▶ Tu constancia da frutos.']
    : health > 40
    ? ['▶ El árbol necesita más agua.', '▶ Algunos hábitos están sin completar.', '▶ No te rindas, ¡aún puedes recuperarte!']
    : ['▶ El árbol se debilita. ¡Actúa ya!', '▶ Las raíces sufren. Completa tus hábitos.', '▶ PELIGRO: El árbol puede morir.'];
  document.getElementById('treeMsg').textContent = msgs[Math.floor(Math.random()*msgs.length)];

  return { stage, progress, health };
}

// ─── WEATHER FX ──────────────────────────────────────────────────────────────
function updateWeather(health) {
  const fx = document.getElementById('weatherFx');
  fx.innerHTML = '';
  if (health < 50) {
    for (let i = 0; i < 20; i++) {
      const r = document.createElement('div');
      r.className = 'raindrop';
      r.style.left = Math.random()*100 + '%';
      r.style.height = (6 + Math.random()*8) + 'px';
      r.style.top = '-10px';
      r.style.animationDuration = (0.6 + Math.random()*0.4) + 's';
      r.style.animationDelay = Math.random()*1 + 's';
      fx.appendChild(r);
    }
  }
}

// ─── PARTICLES ───────────────────────────────────────────────────────────────
function spawnParticles() {
  const canvas = document.getElementById('treeCanvas');
  const rect = canvas.getBoundingClientRect();
  const colors = ['#00ff88','#ffdd00','#ff8800','#44aaff'];
  for (let i = 0; i < 8; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.background = colors[Math.floor(Math.random()*colors.length)];
    p.style.left = (rect.left + rect.width/2 + (Math.random()-0.5)*60) + 'px';
    p.style.top = (rect.top + rect.height/2 + (Math.random()-0.5)*40) + 'px';
    p.style.position = 'fixed';
    p.style.animationDelay = Math.random()*0.3 + 's';
    document.body.appendChild(p);
    setTimeout(() => p.remove(), 2200);
  }
}

// ─── TREE DRAWING ─────────────────────────────────────────────────────────────
function drawTree(progress, health) {
  const canvas = document.getElementById('treeCanvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const dead = health < 20;
  const sick = health < 50;

  if (dead) {
    canvas.classList.add('dead');
  } else {
    canvas.classList.remove('dead');
  }

  // Color palette based on health
  const trunkColor = dead ? '#4a2a0a' : sick ? '#6a3a0f' : '#8B4513';
  const darkTrunk = dead ? '#2a1a05' : sick ? '#4a2a0a' : '#5C2D0A';
  const leafColor = dead ? '#4a4a2a' : sick ? '#6a7a1a' : '#2d8a1a';
  const leafLight = dead ? '#5a5a3a' : sick ? '#8a9a2a' : '#3daa2a';
  const leafDark = dead ? '#3a3a1a' : sick ? '#4a5a0a' : '#1a6a0a';

  // Pixel size
  const px = 4;
  function rect(x, y, w, h, color) {
    ctx.fillStyle = color;
    ctx.fillRect(x*px, y*px, w*px, h*px);
  }

  const cx = W/2/px; // center x in pixels units

  if (progress <= 5) {
    // SEED
    rect(cx-1, 15, 2, 2, '#c8a060');
    rect(cx-1, 14, 2, 1, '#a08040');
    // tiny sprout
    if (progress >= 3) {
      rect(cx, 13, 1, 2, '#3daa2a');
    }

  } else if (progress <= 15) {
    // SPROUT
    // stem
    rect(cx, 12, 1, 4, '#4a7a1a');
    // small leaf
    rect(cx-2, 11, 2, 1, leafColor);
    rect(cx+1, 11, 2, 1, leafColor);
    rect(cx, 10, 1, 1, leafLight);
    // seed
    rect(cx-1, 15, 2, 1, '#c8a060');

  } else if (progress <= 30) {
    // YOUNG PLANT
    // trunk
    rect(cx, 13, 1, 3, trunkColor);
    rect(cx-1, 14, 1, 2, darkTrunk);
    // branches
    rect(cx-3, 11, 3, 1, trunkColor);
    rect(cx+1, 11, 3, 1, trunkColor);
    // leaves
    rect(cx-4, 9, 3, 2, leafColor);
    rect(cx-3, 8, 2, 1, leafLight);
    rect(cx+2, 9, 3, 2, leafColor);
    rect(cx+2, 8, 2, 1, leafLight);
    rect(cx-1, 8, 3, 2, leafLight);
    rect(cx, 7, 1, 1, leafColor);

  } else if (progress <= 55) {
    // STRONG PLANT
    // trunk
    for (let i = 0; i < 5; i++) rect(cx-1, 10+i, 3, 1, trunkColor);
    for (let i = 0; i < 5; i++) rect(cx-1, 10+i, 1, 1, darkTrunk);
    // branches
    rect(cx-5, 8, 4, 1, trunkColor);
    rect(cx+2, 8, 4, 1, trunkColor);
    rect(cx-2, 6, 2, 1, trunkColor);
    rect(cx+1, 6, 2, 1, trunkColor);
    // leaf clusters
    for (let dy = 0; dy < 3; dy++)
      for (let dx = -5; dx < -1; dx++)
        if (Math.abs(dx+3)+dy < 3) rect(cx+dx, 5+dy, 1, 1, dy===0?leafLight:leafColor);
    for (let dy = 0; dy < 3; dy++)
      for (let dx = 2; dx < 6; dx++)
        if (Math.abs(dx-4)+dy < 3) rect(cx+dx, 5+dy, 1, 1, dy===0?leafLight:leafColor);
    // top
    rect(cx-2, 3, 5, 3, leafColor);
    rect(cx-1, 2, 3, 2, leafLight);
    rect(cx, 1, 1, 1, leafLight);
    // dark accents
    rect(cx-2, 5, 1, 1, leafDark);
    rect(cx+2, 5, 1, 1, leafDark);

  } else if (progress <= 80) {
    // BIG TREE
    // thick trunk
    for (let i = 0; i < 7; i++) {
      rect(cx-2, 8+i, 4, 1, trunkColor);
      rect(cx-2, 8+i, 1, 1, darkTrunk);
    }
    // roots
    rect(cx-4, 14, 2, 1, darkTrunk);
    rect(cx+3, 14, 2, 1, darkTrunk);
    // main branches
    rect(cx-7, 6, 5, 1, trunkColor);
    rect(cx+3, 6, 5, 1, trunkColor);
    rect(cx-3, 4, 2, 1, trunkColor);
    rect(cx+2, 4, 2, 1, trunkColor);
    // big canopy
    for (let dy = 0; dy < 8; dy++) {
      const spread = Math.min(6, dy+1, 8-dy);
      for (let dx = -spread; dx <= spread; dx++) {
        const dist = Math.abs(dx) + dy*0.5;
        const c = dist < 2 ? leafLight : dist < 4 ? leafColor : leafDark;
        if (dist < spread+0.5) rect(cx+dx, 1+dy, 1, 1, c);
      }
    }
    // flowers if healthy
    if (!sick) {
      [[cx-3,2],[cx+2,2],[cx-5,5],[cx+4,5],[cx,0]].forEach(([fx,fy]) => {
        rect(fx, fy, 1, 1, '#ff88aa');
      });
    }

  } else {
    // LEGENDARY TREE
    // massive trunk
    for (let i = 0; i < 9; i++) {
      rect(cx-3, 6+i, 6, 1, trunkColor);
      rect(cx-3, 6+i, 2, 1, darkTrunk);
    }
    // roots
    rect(cx-6, 13, 3, 1, darkTrunk);
    rect(cx-5, 14, 2, 1, darkTrunk);
    rect(cx+4, 13, 3, 1, darkTrunk);
    rect(cx+4, 14, 2, 1, darkTrunk);
    // big branches
    rect(cx-9, 4, 6, 1, trunkColor);
    rect(cx+4, 4, 6, 1, trunkColor);
    rect(cx-5, 2, 3, 1, trunkColor);
    rect(cx+3, 2, 3, 1, trunkColor);
    // HUGE canopy
    for (let dy = 0; dy < 12; dy++) {
      const spread = Math.min(9, dy*1.2+1, 12-dy+2);
      for (let dx = -spread; dx <= spread; dx++) {
        const dist = Math.abs(dx)*0.8 + dy*0.4;
        const c = dist < 2 ? '#88ffaa' : dist < 5 ? leafLight : dist < 7 ? leafColor : leafDark;
        if (dist < spread+0.5) rect(cx+dx, -1+dy, 1, 1, c);
      }
    }
    // Stars / glow on legendary
    [[cx-4,0],[cx+3,0],[cx-7,4],[cx+6,4],[cx-2,-1],[cx+1,-1]].forEach(([fx,fy]) => {
      if (fy >= 0) rect(fx, fy, 1, 1, '#ffee44');
    });
    // flowers everywhere
    [[cx-3,1],[cx+2,1],[cx-6,4],[cx+5,4],[cx-1,-1],[cx+0,2],[cx-8,6],[cx+7,6]].forEach(([fx,fy]) => {
      if (fy >= 0) rect(fx, fy, 1, 1, '#ff88cc');
    });
  }
}

// ─── MAIN RENDER ─────────────────────────────────────────────────────────────
function render() {
  const data = loadData();
  const { stage, progress, health } = renderStage(data);
  renderHabits(data);
  renderHistory(data);
  renderStats(data);
  drawTree(progress, health);
  updateWeather(health);
}

// ─── MIDNIGHT AUTO-TICK ───────────────────────────────────────────────────────
function scheduleLogClose() {
  const now = new Date();
  const midnight = new Date(now);
  midnight.setHours(24, 0, 0, 0);
  const ms = midnight - now;
  setTimeout(() => {
    // Mark unfinished required habits as missed
    const data = loadData();
    const today = getTodayStr();
    data.habits.forEach(h => {
      if (shouldDoToday(h, today) && h.log[today] === undefined) {
        h.log[today] = false;
      }
    });
    saveData(data);
    render();
    scheduleLogClose();
  }, ms);
}
scheduleLogClose();

// ─── INIT ────────────────────────────────────────────────────────────────────
render();
setInterval(render, 60000); // re-render every minute
</script>
